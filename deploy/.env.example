# Kiln REST API Proxy -- Environment Variables
# Copy this file to .env and fill in real values before deploying.

# Supabase -- pilot entitlements database
KILN_SUPABASE_URL=https://your-project.supabase.co
KILN_SUPABASE_SERVICE_KEY=eyJ...your-service-role-key

# Craftcloud -- manufacturing quote API
KILN_CRAFTCLOUD_API_KEY=your-craftcloud-api-key

# API authentication -- Bearer token required on all endpoints
KILN_API_AUTH_TOKEN=your-secret-auth-token

# Stripe -- payment processing
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
